    "Cards appear in the Paid with menu when you log a new expense. Existing transactions keep their original card name.": {
      "extractionState": "manual",
      "localizations": {
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "নতুন খরচ লগ করলে কার্ডগুলো \"যা দিয়ে পরিশোধ\" মেনুতে দেখায়। বিদ্যমান লেনদেনগুলো তাদের মূল কার্ড নাম রাখে।"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cards appear in the Paid with menu when you log a new expense. Existing transactions keep their original card name."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las tarjetas aparecen en el menú \"Pagado con\" cuando registras un nuevo gasto. Las transacciones existentes mantienen su nombre de tarjeta original."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "新しい支出を記録するとき、カードは「支払い方法」メニューに表示されます。既存の取引は元のカード名を保持します。"
          }
        }
      }
    },
