    "Monthly principal + interest is computed from the loan amount, rate, and term. Taxes and insurance aren't tracked yet.": {
      "extractionState": "manual",
      "localizations": {
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "মাসিক মূলধন + সুদ ঋণের পরিমাণ, হার ও মেয়াদ থেকে গণনা করা হয়। কর ও বীমা এখনো ট্র্যাক করা হয় না।"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Monthly principal + interest is computed from the loan amount, rate, and term. Taxes and insurance aren't tracked yet."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El capital + interés mensual se calcula a partir del importe del préstamo, la tasa y el plazo. Los impuestos y seguros aún no se registran."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "月々の元本＋利息はローン金額、金利、期間から計算されます。税金と保険はまだ追跡されていません。"
          }
        }
      }
    },
