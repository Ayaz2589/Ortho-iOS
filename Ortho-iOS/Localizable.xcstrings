    "Budgets": {
      "extractionState": "manual",
      "localizations": {
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "বাজেট"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Budgets"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Presupuestos"
          }
        },
        "ja": {
