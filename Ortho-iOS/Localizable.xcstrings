            "value": "Budgets"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Presupuestos"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "予算"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "预算"
          }
        },
        "ko": {
