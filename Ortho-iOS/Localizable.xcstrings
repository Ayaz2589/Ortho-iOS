    "%@ P&I vs %@ income this month. Lenders typically target below 28%%.": {
      "extractionState": "manual",
      "localizations": {
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "এই মাসে %1$@ মূলধন+সুদ বনাম %2$@ আয়। ঋণদাতারা সাধারণত 28%%-এর নিচে রাখার লক্ষ্য রাখেন।"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ P&I vs %@ income this month. Lenders typically target below 28%%."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ capital+interés vs %@ de ingreso este mes. Los prestamistas suelen apuntar a menos del 28%%."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "今月の元本＋利息%@に対して収入%@。貸し手は通常28%%未満を目安にします。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "本月本金+利息%@对比收入%@。贷款机构通常目标为低于28%%。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이번 달 원금+이자 %@, 수입 %@. 대출 기관은 보통 28%% 미만을 목표로 합니다."
          }
        }
      }
    },
