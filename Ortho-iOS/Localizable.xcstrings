    "Add a primary home, a rental, or a multifamily property to track payments, balances, and lease info.": {
      "extractionState": "manual",
      "localizations": {
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "পেমেন্ট, ব্যালেন্স ও লিজ তথ্য ট্র্যাক করতে একটি প্রধান বাড়ি, ভাড়া, বা মাল্টিফ্যামিলি সম্পত্তি যোগ করুন।"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add a primary home, a rental, or a multifamily property to track payments, balances, and lease info."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Añade una vivienda principal, una propiedad en alquiler o una multifamiliar para registrar pagos, saldos e información de arrendamientos."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "支払い、残高、賃貸情報を管理するために自宅、賃貸、集合住宅を追加してください。"
          }
        }
      }
    },
    "Add at least one transaction and it'll show up here for fast duplication.": {
      "extractionState": "manual",
      "localizations": {
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "অন্তত একটি লেনদেন যোগ করুন তাহলে দ্রুত কপির জন্য এটি এখানে দেখাবে।"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add at least one transaction and it'll show up here for fast duplication."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Añade al menos una transacción y aparecerá aquí para duplicarla rápido."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "少なくとも1件の取引を追加すると、ここから素早く複製できます。"
          }
        }
      }
    },
    "Add card": {
      "extractionState": "manual",
      "localizations": {
        "bn": {
