    "Income shows in sage on the Activity list. Selecting multiple owners attributes shared income to all of them.": {
      "extractionState": "manual",
      "localizations": {
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "আয় কার্যকলাপ তালিকায় সাজ রঙে দেখায়। একাধিক মালিক নির্বাচন করলে শেয়ার্ড আয় তাদের সবার মধ্যে বরাদ্দ হয়।"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Income shows in sage on the Activity list. Selecting multiple owners attributes shared income to all of them."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los ingresos se muestran en verde en la lista de actividad. Seleccionar varios propietarios atribuye el ingreso compartido a todos ellos."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "収入はアクティビティリストで緑色で表示されます。複数の所有者を選択すると、共有収入が全員に割り当てられます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "收入在活动列表中以鼠尾草绿色显示。选择多个所有者将共享收入归属于所有人。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "수입은 활동 목록에서 세이지 색상으로 표시됩니다. 여러 소유자를 선택하면 공유 수입이 모두에게 귀속됩니다."
          }
        }
      }
    },
    "Initial is set automatically from the name. Joint accounts get two initials joined with +.": {
      "extractionState": "manual",
      "localizations": {
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "নাম থেকে স্বয়ংক্রিয়ভাবে আদ্যক্ষর সেট হয়। যৌথ অ্যাকাউন্ট + দিয়ে যুক্ত দুটি আদ্যক্ষর পায়।"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Initial is set automatically from the name. Joint accounts get two initials joined with +."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La inicial se establece automáticamente desde el nombre. Las cuentas conjuntas tienen dos iniciales unidas con +."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "イニシャルは名前から自動的に設定されます。共同アカウントは+で結んだ2文字のイニシャルになります。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "首字母会从名字自动设置。联名账户使用两个首字母用+连接。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이니셜은 이름에서 자동으로 설정됩니다. 공동 계정은 두 개의 이니셜을 +로 연결합니다."
          }
        }
      }
    },
