    "Spending in %@ is tracked from the 1st of each calendar month. Insights compare actual spend against this limit.": {
      "extractionState": "manual",
      "localizations": {
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "%@-এ খরচ প্রতি মাসের 1 তারিখ থেকে ট্র্যাক করা হয়। ইনসাইট এই সীমার বিপরীতে প্রকৃত খরচ তুলনা করে।"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Spending in %@ is tracked from the 1st of each calendar month. Insights compare actual spend against this limit."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El gasto en %@ se registra desde el día 1 de cada mes natural. Los insights comparan el gasto real con este límite."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@の支出は毎月1日から記録されます。インサイトはこの上限と実際の支出を比較します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@的支出从每个日历月的1日开始统计。洞察会将实际支出与此限额比较。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
