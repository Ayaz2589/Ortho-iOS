    "By continuing you agree to our **Terms** and **Privacy**.": {
      "extractionState": "manual",
      "localizations": {
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "চালিয়ে যাওয়ার মাধ্যমে আপনি আমাদের **শর্তাবলী** এবং **গোপনীয়তা**-তে সম্মত হন।"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "By continuing you agree to our **Terms** and **Privacy**."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Al continuar aceptas nuestros **Términos** y **Privacidad**."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "続行することで、**利用規約**と**プライバシー**に同意したものとみなします。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "继续即表示您同意我们的**条款**和**隐私政策**。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "계속하면 **약관** 및 **개인정보 처리방침**에 동의하는 것입니다."
          }
        }
      }
    },
