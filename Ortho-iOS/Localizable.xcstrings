            "state": "translated",
            "value": "カードを追加"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "添加卡"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "카드 추가"
          }
        }
      }
    },
    "Add each unit's rent and tenant. Net balance is total unit rent minus the mortgage payment.": {
      "extractionState": "manual",
      "localizations": {
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "প্রতি ইউনিটের ভাড়া ও ভাড়াটে যোগ করুন। নেট ব্যালেন্স হল মোট ইউনিট ভাড়া বিয়োগ মর্টগেজ পেমেন্ট।"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add each unit's rent and tenant. Net balance is total unit rent minus the mortgage payment."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Añade el alquiler y el inquilino de cada unidad. El saldo neto es el alquiler total menos el pago de la hipoteca."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "各ユニットの家賃と入居者を追加してください。純残高は総ユニット家賃から住宅ローン返済を引いた額です。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "添加每个单元的租金和租户。净余额是单元总租金减去按揭还款。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "각 유닛의 임대료와 임차인을 추가하세요. 순잔액은 총 유닛 임대료에서 대출 상환금을 뺀 금액입니다."
          }
        }
      }
    },
