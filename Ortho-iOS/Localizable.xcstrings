    "We'll email you a 6-digit code. No password, no fuss.": {
      "extractionState": "manual",
      "localizations": {
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "আমরা আপনাকে একটি 6-অঙ্কের কোড ইমেইল করব। কোন পাসওয়ার্ড নেই, কোন ঝামেলা নেই।"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We'll email you a 6-digit code. No password, no fuss."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Te enviaremos un código de 6 dígitos por correo. Sin contraseñas, sin complicaciones."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "6桁のコードをメールで送ります。パスワード不要、簡単です。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "我们会通过邮箱发送6位验证码。无需密码，简单便捷。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "6자리 코드를 이메일로 보내드립니다. 비밀번호 없이 간편하게."
          }
        }
      }
    },
    "What kind of home is this? Choose one — we'll ask only the questions that fit.": {
      "extractionState": "manual",
      "localizations": {
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "এটি কোন ধরনের বাড়ি? একটি বেছে নিন — আমরা শুধু প্রাসঙ্গিক প্রশ্ন জিজ্ঞেস করব।"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "What kind of home is this? Choose one — we'll ask only the questions that fit."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Qué tipo de vivienda es esta? Elige una — solo te haremos las preguntas adecuadas."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "これはどんな住宅ですか？1つ選んでください — 必要な質問だけお聞きします。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这是哪种住宅？请选择一个 — 我们只会询问相关的问题。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "어떤 종류의 주택인가요? 하나 선택하세요 — 적합한 질문만 드립니다."
          }
        }
      }
    },
    "Yesterday": {
      "extractionState": "manual",
      "localizations": {
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "গতকাল"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Yesterday"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ayer"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "昨日"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "昨天"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "어제"
          }
        }
      }
    },
    "You can change type later from the property's settings, but a few fields will reset (e.g. lease dates become closing date).": {
      "extractionState": "manual",
      "localizations": {
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "পরে আপনি সম্পত্তির সেটিংস থেকে ধরন পরিবর্তন করতে পারেন, তবে কিছু ক্ষেত্র রিসেট হবে (যেমন লিজের তারিখ ক্লোজিং তারিখ হবে)।"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You can change type later from the property's settings, but a few fields will reset (e.g. lease dates become closing date)."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Puedes cambiar el tipo más tarde desde los ajustes de la propiedad, pero algunos campos se reiniciarán (p. ej. las fechas del contrato pasan a fecha de cierre)."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "後で物件設定から種類を変更できますが、一部のフィールドはリセットされます（例: 賃貸日がクロージング日になる）。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您可以稍后在房产设置中更改类型，但部分字段将重置（例如租约日期变为成交日期）。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "나중에 부동산 설정에서 유형을 변경할 수 있지만 일부 필드는 재설정됩니다(예: 임대 날짜가 마감일로 변경됨)."
          }
        }
      }
    },
    "You own where you live": {
      "extractionState": "manual",
      "localizations": {
        "bn": {
          "stringUnit": {
