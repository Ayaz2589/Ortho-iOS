    "%@ P&I vs %@ income this month. Lenders typically target below 28%%.": {
      "extractionState": "manual",
      "localizations": {
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "এই মাসে %1$@ মূলধন+সুদ বনাম %2$@ আয়। ঋণদাতারা সাধারণত 28%%-এর নিচে রাখার লক্ষ্য রাখেন।"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ P&I vs %@ income this month. Lenders typically target below 28%%."
          }
        }
      }
    },
