    "Personal transactions are visible only to you. They don't appear in the household's shared list.": {
      "extractionState": "manual",
      "localizations": {
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "ব্যক্তিগত লেনদেন শুধু আপনি দেখতে পারেন। এগুলো পরিবারের শেয়ার্ড তালিকায় দেখা যায় না।"
