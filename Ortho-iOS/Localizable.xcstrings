    "You'll need to sign in again next time you open Ortho.": {
      "extractionState": "manual",
      "localizations": {
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "পরবর্তী বার অর্থো খুললে আপনাকে আবার সাইন ইন করতে হবে।"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You'll need to sign in again next time you open Ortho."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tendrás que iniciar sesión de nuevo la próxima vez que abras Ortho."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "次回Orthoを開くときに再度サインインが必要です。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您下次打开Ortho时需要重新登录。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "다음에 Ortho를 열 때 다시 로그인해야 합니다."
          }
        }
      }
    },
    "You're %@ over this month: %@ out vs %@ in.": {
      "extractionState": "manual",
      "localizations": {
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "এই মাসে %1$@ বেশি: %3$@ আয়, %2$@ খরচ।"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You're %@ over this month: %@ out vs %@ in."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Estás %@ por encima este mes: %@ de salida vs %@ de entrada."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "今月%@超過: 支出%@に対して収入%@。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "本月超支%@：支出%@对比收入%@。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이번 달 %@ 초과: 지출 %@, 수입 %@."
          }
        }
      }
    },
    "You're %@ over your %@ limit with %lld days left.": {
      "extractionState": "manual",
      "localizations": {
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "%3$lld দিন বাকি — %2$@ সীমার %1$@ বেশি।"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You're %@ over your %@ limit with %lld days left."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Estás %@ por encima de tu límite de %@ con %lld días restantes."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "残り%lld日で、%@の上限を%@超過しています。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "还剩%lld天，您已超出%@的%@限额%@。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld일 남았는데, %@ 한도를 %@ 초과했습니다."
          }
        }
      }
    },
