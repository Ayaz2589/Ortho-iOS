    "Log an expense or income to see it grouped by day here.": {
      "extractionState": "manual",
      "localizations": {
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "এখানে দিন অনুযায়ী গ্রুপ দেখতে একটি খরচ বা আয় যোগ করুন।"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Log an expense or income to see it grouped by day here."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Registra un gasto o ingreso para verlo agrupado por día aquí."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "支出や収入を記録すると、ここに日付ごとに表示されます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "记录一笔支出或收入，将按日期分组显示在这里。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "지출이나 수입을 기록하면 여기에 날짜별로 표시됩니다."
          }
        }
      }
    },
